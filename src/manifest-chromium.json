{
    "manifest_version": 3,
    "name": "Deslopify",
    "version": "0.6",
    "version_name": "Beta build 6",

    "description": "Blocks AI slop elements from supported websites.",

    "icons": {
        "48": "icons/icon.svg"
    },

    "permissions": ["scripting", "tabs"],

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["deslopifycrx.js"]
        }
    ],

    "background": {
        "service_worker": "backgroundcrx.js",
        "type": "module"
    },

    "action": {
        "default_icon": {
            "48": "icons/icon.svg"
        },
        "default_title": "Deslopify"
    },

    "web_accessible_resources": [
        {
            "resources": [
                "blocklist.json"
            ],
            "matches": []
        }
    ]
}
