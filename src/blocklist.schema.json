{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string"
        },
        "format_version": {
            "type": "number"
        }
    },
    "required": ["$schema", "format_version"],
    "additionalProperties": {
        "type": "object",
        "properties": {
            "classes": {
                "type": "array",
                "items": {
                    "type": "string"
                }
            },
            "IDs": {
                "type": "array",
                "items": {
                    "type": "string"
                }
            },
            "otherIdentifiers": {
                "type": "array",
                "items": {
                    "type": "string"
                }
            },
            "textContent": {
                "type": "array",
                "items": {
                    "type": "string"
                }
            }
        },
        "required": ["classes", "IDs", "otherIdentifiers", "textContent"]
    }
}
