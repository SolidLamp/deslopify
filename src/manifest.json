{
    "manifest_version": 3,
    "name": "Deslopify",
    "version": "0.6",
    "version_name": "Beta build 6",

    "description": "Blocks AI slop elements from supported websites.",

    "icons": {
        "48": "icons/icon.svg"
    },

    "permissions": ["scripting", "tabs"],

    "browser_specific_settings": {
        "gecko": {
            "id": "deslopify@solid.lamp",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["deslopify.mjs"]
        }
    ],

    "gecko:background": {
        "scripts": ["background.mjs"],
        "persistent": false,
        "type": "module"
    },

    "chromium:background": {
        "service_worker": "background.mjs",
        "type": "module"
    },

    "action": {
        "default_icon": {
            "48": "icons/icon.svg"
        },
        "default_title": "Deslopify"
    },

    "web_accessible_resources": [
        {
            "resources": ["blocklist.json", "blocklist.schema.json"],
            "matches": []
        }
    ]
}
