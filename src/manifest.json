{
    "manifest_version": 3,
    "name": "Deslopify",
    "version": "0.8",
    "version_name": "Beta build 8",

    "description": "A content blocker which hides 'in-your-face AI' elements on supported websites.",

    "icons": {
        "48": "icons/icon.svg"
    },

    "permissions": ["scripting", "tabs"],

    "browser_specific_settings": {
        "gecko": {
            "id": "deslopify@solid.lamp",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["deslopify.ts"]
        }
    ],

    "gecko:background": {
        "scripts": ["background.ts"],
        "persistent": false,
        "type": "module"
    },

    "chromium:background": {
        "service_worker": "background.ts",
        "type": "module"
    },

    "action": {
        "default_icon": {
            "48": "icons/icon.svg"
        },
        "default_title": "Deslopify"
    },

    "web_accessible_resources": [
        {
            "resources": ["blocklist.json", "blocklist.schema.json", "LICENSE"],
            "matches": []
        }
    ]
}
