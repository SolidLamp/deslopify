{
    "manifest_version": 3,
    "name": "Deslopify",
    "version": "0.4",
    "version_name": "Beta build 4",

    "description": "Blocks AI slop elements from supported websites.",

    "icons": {
        "48": "icons/border-48.png"
    },

    "permissions": ["scripting", "tabs"],

    "browser_specific_settings": {
        "gecko": {
            "id": "deslopify@solid.lamp",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["deslopify.js"]
        }
    ],

    "background": {
        "scripts": ["background.js"],
        "persistent": false,
        "type": "module"
    },

    "action": {
        "default_icon": {
            "48": "icons/border-48.png"
        },
        "default_title": "Deslopify"
    },

    "web_accessible_resources": [
        {
            "resources": [
                "blocklist.json"
            ],
            "matches": []
        }
    ]
}
